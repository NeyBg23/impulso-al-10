# Variables de Entorno - Impulso al 10

# ===== BACKEND (Node.js) =====
NODE_ENV=production
JWT_SECRET=tu_jwt_secret_fuerte_aqui

# ===== BASE DE DATOS =====
DATABASE_URL=postgresql://usuario:contraseña@host:5432/database

# ===== SUPABASE (BDD actual) =====
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_clave_anonima
SUPABASE_SERVICE_ROLE_KEY=tu_clave_servicio

# ===== OAUTH =====
VITE_APP_ID=tu_app_id
VITE_OAUTH_PORTAL_URL=https://tu-oauth-server.com
OAUTH_SERVER_URL=https://tu-oauth-server.com/api/oauth
OWNER_OPEN_ID=tu_owner_id

# ===== APIs EXTERNAS (Forge/Storage) =====
BUILT_IN_FORGE_API_URL=https://tu-api.mindsync.co
BUILT_IN_FORGE_API_KEY=tu_api_key
VITE_FRONTEND_FORGE_API_URL=https://tu-api.mindsync.co
VITE_FRONTEND_FORGE_API_KEY=tu_api_key_frontend

# ===== ANALYTICS (Opcional) =====
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=tu_website_id
